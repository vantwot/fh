    "express": "^4.19.2",
    "jspdf": "^4.2.1",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
